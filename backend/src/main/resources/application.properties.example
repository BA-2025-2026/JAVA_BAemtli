# API Versioning
server.servlet.context-path=/api/v1
# Application name
spring.application.name=baemtli

# Syntax of variables: ${ENV_VARIABLE_LOADED_FROM_DOTENV:yourOwnFallbackValue}
spring.datasource.url=jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:baemtli}
spring.datasource.username=${DB_USER:pleasechange}
spring.datasource.password=${DB_PASSWORD:pleasechange}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl